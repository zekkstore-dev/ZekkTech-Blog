# === SITE CONFIG ===
# URL Situs Anda (untuk SEO, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://zekktech.com

# === SUPABASE ENV ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === CLOUDFLARE R2 ENV ===
# ID Akun Cloudflare (Dapatkan dari Dashboard R2)
R2_ACCOUNT_ID=your-account-id
# Akses Kunci S3
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# Nama Ember (Bucket)
R2_BUCKET_NAME=your-bucket-name
# Domain R2 Kustom Anda (Atau Public R2 dev domain tanpa https://)
# Contoh: pub-f2a9xxxxxxxx.r2.dev
NEXT_PUBLIC_R2_DOMAIN=your-public-r2.dev

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# === GOOGLE ANALYTICS ===
# Dapatkan dari Google Analytics Dashboard (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=your-ga-measurement-id
